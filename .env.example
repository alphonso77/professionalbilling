NODE_ENV=development
PORT=3000
API_BASE_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173

# Superuser connection — migrations, workers, admin paths (bypasses RLS).
DATABASE_URL=postgres://postgres:postgres@localhost:5432/professionalbilling
# Restricted role — API handlers (RLS enforced). Falls back to DATABASE_URL if unset (dev only).
DATABASE_APP_URL=postgres://professionalbilling_app:app@localhost:5432/professionalbilling

REDIS_URL=redis://localhost:6379

CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=
CLERK_WEBHOOK_SIGNING_SECRET=

STRIPE_SECRET_KEY=
STRIPE_CLIENT_ID=
STRIPE_WEBHOOK_SECRET=
STRIPE_CONNECT_REDIRECT_URI=http://localhost:3000/api/oauth/callback/stripe

RESEND_API_KEY=

# 32-byte key as 64-char hex (AES-256-GCM for Stripe Connect tokens).
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=

LOG_LEVEL=info
