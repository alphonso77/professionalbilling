{
  "name": "professionalbilling",
  "version": "0.1.0",
  "description": "Professional billing for lawyers, consultants, and accountants — time tracking, invoicing, configurable alerts.",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json && tsc-alias -p tsconfig.json",
    "start": "node dist/server.js",
    "test": "mocha",
    "test:watch": "mocha --watch --watch-files 'src/**/*.ts,test/**/*.ts'",
    "typecheck": "tsc --noEmit",
    "migrate": "knex migrate:latest --knexfile datastore/knexfile.js",
    "migrate:make": "knex migrate:make --knexfile datastore/knexfile.js",
    "migrate:rollback": "knex migrate:rollback --knexfile datastore/knexfile.js",
    "seed": "knex seed:run --knexfile datastore/knexfile.js",
    "setup:webhooks": "tsx src/scripts/setup-webhooks.ts",
    "worker:stripe-events": "tsx src/workers/stripe-events.ts"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^7.3.0",
    "@clerk/backend": "^3.2.3",
    "@clerk/express": "^1.3.0",
    "axios": "^1.7.0",
    "bullmq": "^5.20.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.21.0",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.0",
    "knex": "^3.1.0",
    "morgan": "^1.10.0",
    "pg": "^8.13.0",
    "resend": "^6.9.4",
    "stripe": "^22.0.0",
    "swagger-ui-express": "^5.0.1",
    "winston": "^3.14.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/chai": "^5.0.0",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/mocha": "^10.0.0",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.0.0",
    "@types/swagger-ui-express": "^4.1.6",
    "chai": "^5.1.0",
    "mocha": "^11.1.0",
    "tsc-alias": "^1.8.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
